# WPBot environment — copy to .env and fill in your values.

# -------------------------
# API Server
# -------------------------
API_HOST=127.0.0.1            # Flask bind address (use 0.0.0.0 in containers)
API_PORT=5000                 # Flask port
FLASK_ENV=production          # production | development

# -------------------------
# Chrome / WhatsApp Automation
# -------------------------
CHROME_HEADLESS=false         # true = headless Chrome (no UI)
BROWSER_ROOT_DIR=Browser      # Chrome user-data profiles (gitignored)
WHATSAPP_URL=https://web.whatsapp.com/
LOGIN_TIMEOUT_SECONDS=120     # Seconds to wait for QR login

# -------------------------
# Capacity / Autoscaling
# -------------------------
TASKS_PER_PROFILE=10          # Pending targets per ready profile before scaling up
SCALE_INTERVAL_SECONDS=5      # Autoscaler check interval
PROFILE_START_DELAY_SECONDS=4 # Delay between spawning new profiles

# -------------------------
# Database (required — replace placeholders)
# -------------------------
DB_HOSTNAME=YOUR_DB_HOST
DB_NAME=YOUR_DB_NAME
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_PORT=3306
DB_CHARSET=utf8mb4

# -------------------------
# Time Zone
# -------------------------
APP_TIMEZONE=Europe/Istanbul  # Used for /status timestamps
APP_TZ_OFFSET_HOURS=3         # Fallback if zoneinfo unavailable

# -------------------------
# Logging
# -------------------------
LOG_DIR=logs
LOG_LEVEL=INFO

# -------------------------
# Initial Profiles
# -------------------------
INITIAL_PROFILES=1            # Chrome profiles started at launch
